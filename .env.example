# Сервер / Vercel (секреты — только здесь или в Vercel Environment Variables, не во фронте)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Локальная разработка: порт Express API (vite proxy → этот порт). На Vercel не нужен.
# APP_PORT=8787

# Админка (клиент, опционально)
# VITE_ADMIN_LOGIN=admin
# VITE_ADMIN_PASSWORD=

# Только если фронт без прокси (редко): полный URL API без слэша в конце
# VITE_API_BASE_URL=
