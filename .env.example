# Сервер / Vercel / Cloudflare Pages Functions (секреты — не во фронте, только в env деплоя)
# На Cloudflare Pages: Settings → Environment variables → Production (и Preview при необходимости)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Локальная разработка: порт Express API (vite proxy → этот порт). На Vercel не нужен.
# APP_PORT=8787

# Админка (клиент, опционально)
# VITE_ADMIN_LOGIN=admin
# VITE_ADMIN_PASSWORD=

# Только локально / dev (vite без прокси): URL API без слэша в конце.
# На production (Cloudflare Pages) в коде VITE_API_BASE_URL не используется — всегда /api/applications на том же домене.
# VITE_API_BASE_URL=http://127.0.0.1:8787
